# ── Supabase (instancia nueva para SleepAgent, separada del spa) ────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Webhook auth — header compartido con Health Auto Export ─────────────────
# Generá uno random, ej: openssl rand -hex 32
INGEST_SECRET=

# ── ngrok static domain (gratis, 1 por cuenta) ──────────────────────────────
# Crear en https://dashboard.ngrok.com/domains
# Pegar solo el dominio, sin https:// ni path. Ej: mateo-sleep.ngrok-free.app
NGROK_DOMAIN=

# ── Anthropic (F1.5 — generación del reporte) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── Destinatario del reporte por WhatsApp ───────────────────────────────────
MY_PHONE=598XXXXXXXX

# ── Reporte diario (F1.5) ───────────────────────────────────────────────────
TZ=America/Montevideo
REPORT_HOUR=8
REPORT_MINUTE=30
